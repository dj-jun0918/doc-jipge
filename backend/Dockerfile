FROM python:3.13-slim

WORKDIR /app

# LibreOffice + Java + libreoffice-java-common (LibreOfficeвҶ”Java лёҢлҰҝм§Җ)
# H2OrestartлҠ” JavaлЎң мһ‘м„ұлҗң LibreOffice нҷ•мһҘмқҙлқј Java лёҢлҰҝм§Җк°Җ н•„мҲҳ
RUN apt-get update && apt-get install -y --no-install-recommends \
    libreoffice-writer \
    libreoffice-java-common \
    default-jre-headless \
    wget \
    unzip \
    curl \
    && wget -q https://github.com/ebandal/H2Orestart/releases/latest/download/H2Orestart.oxt -O /tmp/H2Orestart.oxt \
    && unopkg add --shared /tmp/H2Orestart.oxt \
    && rm /tmp/H2Orestart.oxt \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Playwright Chromium (K-Startup, мӨ‘кё°л¶Җ мҠӨнҒ¬лһҳн•‘)
RUN pip install --no-cache-dir playwright \
    && playwright install --with-deps chromium

# Python мқҳмЎҙм„ұ (мқҳмЎҙм„ұ мәҗмӢң л Ҳмқҙм–ҙ л¶„лҰ¬)
COPY pyproject.toml .
RUN mkdir -p app && touch app/__init__.py \
    && pip install --no-cache-dir -e . \
    && rm -rf app

# мӢӨм ң мҶҢмҠӨ мҪ”л“ң ліөмӮ¬
COPY app/ app/

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
